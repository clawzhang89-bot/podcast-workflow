#!/usr/bin/env python3
import argparse
import json
import os
import re
from pathlib import Path
from urllib.request import Request, urlopen

OPENAI_API_URL = os.getenv('OPENAI_API_URL', 'https://api.openai.com/v1/chat/completions')
OPENAI_MODEL = os.getenv('PODCAST_SCRIPT_MODEL', os.getenv('OPENAI_MODEL', 'gpt-5.4'))

SYSTEM_PROMPT = '''你是中文分析型播客编剧。你的任务是把输入的中文纯文本，改写成适合双人中文播客口播的对话稿。

硬性要求：
1. 只输出多行纯文本，不要 Markdown，不要解释，不要标题。
2. 每一行必须严格使用 `A|内容` 或 `B|内容` 格式。
3. A 负责控场、切主题、提炼主线、推动结构；B 负责补充、追问、解释含义、把抽象内容讲白。
4. 风格要像中文分析型播客，不像新闻播报，不像论文朗读，不像客服问答。
5. 不要互相吹捧，不要“欢迎收听”式空话，不要故作夸张，不要虚假互动。
6. 保留原文核心信息，不要编造事实。
7. 每轮只说 1 到 2 句；每句尽量短，适合 TTS 口播。
8. 避免每一轮都用同一种连接词，避免模板感。
9. B 不要只是重复 A，要推进理解。
10. 允许优化语气、衔接和文本编排，但不能改变原文事实、判断方向、因果关系和语义强弱。
11. 不得添加原文没有的新事实、新结论、新数据、新推断。
12. 不得把原文中的可能性表述改成确定性表述，不得把边际变化改写成趋势反转。
13. 如果原文表达保留、模糊、审慎，输出也必须保持同样的审慎程度。
14. 整体听感应更像两个人在分析同一件事，而不是轮流念提纲。
15. 不要输出任何不是 A| 或 B| 开头的行。
'''

USER_TEMPLATE = '''请把下面这段内容改写成双人播客对话稿。

约束：
- 目标轮数：{turns} 轮左右。
- 每句尽量控制在 {max_chars} 个汉字以内；必要时可以更短。
- 默认偏中文财经 / 研究 /分析类节目风格。
- 如果原文结构很硬（比如“第一、第二、第三”），改写时尽量口语化。
- A 负责搭框架，B 负责解释原因、补充影响、把话讲透。
- 少一点解释腔，多一点分析型对谈感。
- 只能对表达方式做优化，不能改变原文含义本身。
- 事实保真优先于文风优化。
- 如果原文信息不多，不要硬凑轮数。

原文如下：
{text}
'''


def clean_text(text: str) -> str:
    text = text.replace('\r', '\n')
    text = re.sub(r'\n+', '\n', text)
    text = re.sub(r'[ \t]+', ' ', text)
    return text.strip()


def validate_dialogue(text: str, max_chars: int) -> str:
    lines = [line.strip() for line in text.splitlines() if line.strip()]
    if not lines:
        raise SystemExit('Model returned empty output')
    bad = [line for line in lines if not (line.startswith('A|') or line.startswith('B|'))]
    if bad:
        raise SystemExit('Model output invalid; found non A|/B| lines: ' + bad[0][:120])
    normalized = []
    for line in lines:
        role, content = line.split('|', 1)
        content = content.strip()
        if len(content) > max_chars * 2:
            raise SystemExit(f'Model output line too long for TTS: {line[:160]}')
        normalized.append(f'{role}|{content}')
    return '\n'.join(normalized) + '\n'


def generate_dialogue(text: str, turns: int, max_chars: int) -> str:
    api_key = os.getenv('OPENAI_API_KEY')
    if not api_key:
        raise SystemExit('OPENAI_API_KEY is not set')
    payload = {
        'model': OPENAI_MODEL,
        'messages': [
            {'role': 'system', 'content': SYSTEM_PROMPT},
            {'role': 'user', 'content': USER_TEMPLATE.format(text=text, turns=turns, max_chars=max_chars)},
        ],
        'temperature': 0.7,
    }
    data = json.dumps(payload, ensure_ascii=False).encode('utf-8')
    req = Request(OPENAI_API_URL, data=data, method='POST')
    req.add_header('Authorization', f'Bearer {api_key}')
    req.add_header('Content-Type', 'application/json')
    with urlopen(req) as resp:
        obj = json.loads(resp.read().decode('utf-8'))
    content = obj['choices'][0]['message']['content']
    return validate_dialogue(content, max_chars=max_chars)


def main():
    ap = argparse.ArgumentParser(description='Convert plain Chinese text into A| / B| dialogue draft with an LLM')
    ap.add_argument('--file', help='Input text file')
    ap.add_argument('--text', help='Direct text input')
    ap.add_argument('-o', '--output', required=True, help='Output dialogue file')
    ap.add_argument('--turns', type=int, default=10, help='Target number of turns')
    ap.add_argument('--max-chars', type=int, default=36, help='Target max chars per spoken line')
    args = ap.parse_args()

    text = args.text
    if args.file:
        text = Path(args.file).read_text(encoding='utf-8')
    if not text:
        raise SystemExit('Provide --file or --text')

    out = Path(args.output)
    out.parent.mkdir(parents=True, exist_ok=True)
    result = generate_dialogue(clean_text(text), turns=args.turns, max_chars=args.max_chars)
    out.write_text(result, encoding='utf-8')
    print(out)


if __name__ == '__main__':
    main()
