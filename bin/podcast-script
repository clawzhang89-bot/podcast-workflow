#!/usr/bin/env python3
import argparse
import re
from pathlib import Path

OPENERS_A = [
    '今天这段内容，先抓主线。',
    '我们先把这段内容拆开看。',
    '这段信息里，最重要的是主线变化。',
]
FOLLOW_B = [
    '这里面更值得留意的是，',
    '如果往下拆，核心其实是，',
    '换个更直接的说法，',
]
TRANSITION_A = [
    '再往下看，',
    '下一层更关键的是，',
    '如果把这件事接着推，',
]
CLOSE_B = [
    '所以最后落到判断上，',
    '所以真正需要记住的是，',
    '所以从决策角度看，',
]


def clean_text(text: str) -> str:
    text = text.replace('\r', '\n')
    text = re.sub(r'\n+', '\n', text)
    text = re.sub(r'[ \t]+', ' ', text)
    return text.strip()


def split_sentences(text: str):
    parts = re.split(r'(?<=[。！？!?])\s*', text)
    return [p.strip() for p in parts if p.strip()]


def pair_sentences(sentences, max_chars=54):
    out = []
    buf = ''
    for s in sentences:
        s = s.strip()
        if not buf:
            buf = s
        elif len(buf) + len(s) <= max_chars:
            buf += s
        else:
            out.append(buf)
            buf = s
    if buf:
        out.append(buf)
    return out


def strip_lead(chunk: str) -> str:
    return re.sub(r'^(第一|第二|第三|另外|此外|同时|最后)[，、:]?', '', chunk).strip()


def style_line(role: str, idx: int, total: int, chunk: str) -> str:
    chunk = strip_lead(chunk)
    if role == 'A':
        if idx == 0:
            return OPENERS_A[0] + chunk
        if idx >= total - 2:
            return TRANSITION_A[1] + chunk
        return TRANSITION_A[idx % len(TRANSITION_A)] + chunk
    else:
        if idx >= total - 1:
            return CLOSE_B[0] + chunk
        return FOLLOW_B[idx % len(FOLLOW_B)] + chunk


def to_dialogue(text: str):
    sentences = split_sentences(clean_text(text))
    chunks = pair_sentences(sentences)
    lines = []
    role = 'A'
    for i, chunk in enumerate(chunks):
        chunk = chunk.strip()
        if not chunk:
            continue
        line = style_line(role, i, len(chunks), chunk)
        lines.append(f'{role}|{line}')
        role = 'B' if role == 'A' else 'A'
    return '\n'.join(lines) + '\n'


def main():
    ap = argparse.ArgumentParser(description='Convert plain Chinese text into A| / B| dialogue draft')
    ap.add_argument('--file', help='Input text file')
    ap.add_argument('--text', help='Direct text input')
    ap.add_argument('-o', '--output', required=True, help='Output dialogue file')
    args = ap.parse_args()

    text = args.text
    if args.file:
        text = Path(args.file).read_text(encoding='utf-8')
    if not text:
        raise SystemExit('Provide --file or --text')

    out = Path(args.output)
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(to_dialogue(text), encoding='utf-8')
    print(out)


if __name__ == '__main__':
    main()
