#!/usr/bin/env python3
import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
TTS = ROOT / 'bin' / 'doubao-tts'


def parse_lines(path: Path):
    items = []
    for raw in path.read_text(encoding='utf-8').splitlines():
        line = raw.strip()
        if not line or line.startswith('#'):
            continue
        if '|' not in line:
            raise SystemExit(f'Invalid line (missing |): {line}')
        role, text = line.split('|', 1)
        role = role.strip()
        text = text.strip()
        if role not in {'A', 'B'}:
            raise SystemExit(f'Invalid role {role!r}; expected A or B')
        if not text:
            raise SystemExit(f'Empty text for role {role}')
        items.append((role, text))
    if not items:
        raise SystemExit('No dialogue lines found')
    return items


def run(cmd):
    subprocess.run(cmd, check=True)


def main():
    ap = argparse.ArgumentParser(description='Generate two-speaker dialogue mp3 from A| / B| text format')
    ap.add_argument('--file', required=True, help='Dialogue text file')
    ap.add_argument('-o', '--output', required=True, help='Output mp3 path')
    ap.add_argument('--speaker-a', default='zh_female_mizai_uranus_bigtts')
    ap.add_argument('--speaker-b', default='zh_male_dayi_uranus_bigtts')
    ap.add_argument('--volume-a', type=int, default=100)
    ap.add_argument('--volume-b', type=int, default=85)
    ap.add_argument('--sample-rate', type=int, default=24000)
    ap.add_argument('--workdir', default=str(ROOT / 'tmp' / 'dialogue-build'))
    args = ap.parse_args()

    src = Path(args.file)
    out = Path(args.output)
    workdir = Path(args.workdir)
    if workdir.exists():
        shutil.rmtree(workdir)
    workdir.mkdir(parents=True, exist_ok=True)
    parts_dir = workdir / 'parts'
    audio_dir = workdir / 'audio'
    parts_dir.mkdir()
    audio_dir.mkdir()

    items = parse_lines(src)
    cfg = {
        'A': {'speaker': args.speaker_a, 'volume': args.volume_a},
        'B': {'speaker': args.speaker_b, 'volume': args.volume_b},
    }

    for idx, (role, text) in enumerate(items, 1):
        txt = parts_dir / f'{idx:02d}_{role}.txt'
        mp3 = audio_dir / f'{idx:02d}.mp3'
        txt.write_text(text, encoding='utf-8')
        cmd = [
            str(TTS), '--file', str(txt), '-s', cfg[role]['speaker'], '-o', str(mp3),
            '--sample-rate', str(args.sample_rate), '--volume', str(cfg[role]['volume']),
            '--uid', f'dialogue-{idx:02d}'
        ]
        run(cmd)

    list_file = audio_dir / 'list.txt'
    list_file.write_text(''.join([f"file '{audio_dir}/{i:02d}.mp3'\n" for i in range(1, len(items)+1)]), encoding='utf-8')
    out.parent.mkdir(parents=True, exist_ok=True)
    run(['ffmpeg', '-y', '-f', 'concat', '-safe', '0', '-i', str(list_file), '-c', 'copy', str(out)])
    print(json.dumps({
        'ok': True,
        'output': str(out),
        'lines': len(items),
        'speaker_a': args.speaker_a,
        'speaker_b': args.speaker_b,
        'volume_a': args.volume_a,
        'volume_b': args.volume_b,
    }, ensure_ascii=False))


if __name__ == '__main__':
    main()
